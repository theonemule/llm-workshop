# Azure OpenAI Configuration
# Get these values from your Azure Portal
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2023-05-15

# Milvus Vector Database Configuration
# Set to your Milvus server host (use "localhost" for local development or "milvus" for Docker)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Flask Application Configuration (optional)
# Set to False for production deployments
FLASK_DEBUG=True
FLASK_ENV=development

# Database Configuration (optional)
# Path to SQLite database file
SQLITE_DB_PATH=JEOPARDY.db
